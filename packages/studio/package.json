{
  "name": "@seedforge/studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "seedforge-studio": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/main.ts --dts --clean --format esm --no-splitting",
    "dev": "tsup src/index.ts src/main.ts --dts --watch --format esm --no-splitting",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist client/dist"
  },
  "dependencies": {
    "@seedforge/adapter-mongodb": "workspace:*",
    "@seedforge/adapter-mysql": "workspace:*",
    "@seedforge/adapter-postgres": "workspace:*",
    "@seedforge/core": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0",
    "jiti": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xyflow/react": "^12.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
