{
  "name": "@seedforge/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "seedforge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm",
    "dev": "tsup src/index.ts --dts --watch --format esm",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@seedforge/core": "workspace:*",
    "@seedforge/adapter-postgres": "workspace:*",
    "@seedforge/adapter-mysql": "workspace:*",
    "@seedforge/adapter-mongodb": "workspace:*",
    "@anthropic-ai/sdk": "^0.27.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  }
}
