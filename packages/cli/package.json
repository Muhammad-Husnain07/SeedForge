{
  "name": "@seed-forge/cli",
  "version": "0.2.6",
  "description": "SeedForge CLI — seed, generate, validate, suggest, introspect, diff, export, import, reset, doctor, studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-Husnain07/SeedForge.git"
  },
  "author": "Muhammad Husnain",
  "type": "module",
  "bin": {
    "seedforge": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./commands/init": {
      "import": "./dist/commands/init.js",
      "types": "./dist/commands/init.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm",
    "dev": "tsup src/index.ts --dts --watch --format esm",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.24.1",
    "@inquirer/prompts": "^8.5.2",
    "@seed-forge/adapter-mongodb": "workspace:^",
    "@seed-forge/adapter-mysql": "workspace:^",
    "@seed-forge/adapter-postgres": "workspace:^",
    "@seed-forge/adapter-drizzle": "workspace:^",
    "@seed-forge/adapter-prisma": "workspace:^",
    "@seed-forge/core": "workspace:^",
    "@seed-forge/studio": "workspace:^",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "jiti": "^2.7.0",
    "openai": "^6.45.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "tar": "^7.5.19"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
