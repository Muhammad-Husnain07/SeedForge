{
  "name": "@seedforge/cli",
  "version": "0.0.0",
  "description": "SeedForge CLI — seed, generate, validate, suggest, introspect, diff, export, import, reset, doctor, studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-Husnain07/SeedForge.git"
  },
  "author": "Muhammad Husnain",

  "type": "module",
  "bin": {
    "seedforge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm",
    "dev": "tsup src/index.ts --dts --watch --format esm",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.24.1",
    "@inquirer/prompts": "^8.5.2",
    "@seedforge/adapter-mongodb": "workspace:*",
    "@seedforge/adapter-mysql": "workspace:*",
    "@seedforge/adapter-postgres": "workspace:*",
    "@seedforge/core": "workspace:*",
    "@seedforge/studio": "workspace:*",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "jiti": "^2.7.0",
    "openai": "^6.45.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
