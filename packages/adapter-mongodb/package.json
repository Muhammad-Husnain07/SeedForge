{
  "name": "@seed-forge/adapter-mongodb",
  "version": "0.2.4",
  "description": "MongoDB adapter — schema inference (document sampling, nested flattening, extended JSON) and bulk writer (insertMany) for SeedForge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-Husnain07/SeedForge.git"
  },
  "author": "Muhammad Husnain",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm",
    "dev": "tsup src/index.ts --dts --watch --format esm",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@seed-forge/core": "workspace:^",
    "mongodb": "^6.7.0"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
