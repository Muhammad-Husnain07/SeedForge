{
  "name": "@seedforge/adapter-postgres",
  "version": "0.1.0",
  "description": "Postgres adapter — introspection (INFORMATION_SCHEMA + pg_catalog) and bulk writer (multi-row INSERT + COPY) for SeedForge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-Husnain07/SeedForge.git"
  },
  "author": "Muhammad Husnain",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm",
    "dev": "tsup src/index.ts --dts --watch --format esm",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@seedforge/core": "workspace:*",
    "pg": "^8.12.0",
    "pg-copy-streams": "^7.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/pg-copy-streams": "^1.2.5",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
