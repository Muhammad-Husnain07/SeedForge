{
  "name": "@seedforge/core",
  "version": "0.0.0",
  "description": "Schema IR, relationship graph, semantic analyzer, distributions, config DSL, generation engine, validation layer, lockfile, bundle, and plugin system — database-agnostic core",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-Husnain07/SeedForge.git"
  },
  "author": "Muhammad Husnain",

  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/generate/worker.ts --dts --clean --format esm --no-splitting",
    "dev": "tsup src/index.ts --dts --watch --format esm",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.0",
    "tar": "^7.5.19",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/tar": "^7.0.87",
    "fast-check": "^4.8.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
