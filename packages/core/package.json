{
  "name": "@seedforge/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm",
    "dev": "tsup src/index.ts --dts --watch --format esm",
    "test": "vitest run --reporter verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  }
}
